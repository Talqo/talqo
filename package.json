{
	"name": "talqo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=!@talqo/docs --ui=tui",
		"docs:dev": "pnpm --filter @talqo/docs dev",
		"format": "oxfmt --check",
		"format:fix": "oxfmt .",
		"lint": "oxlint --deny-warnings --report-unused-disable-directives .",
		"lint:fix": "oxlint --deny-warnings --report-unused-disable-directives --fix .",
		"prepare": "husky",
		"quality": "turbo run lint format --output-logs=errors-only",
		"quality:fix": "turbo run lint:fix format:fix --output-logs=errors-only",
		"test": "turbo run test --output-logs=errors-only",
		"typecheck": "turbo run typecheck --output-logs=errors-only"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"husky": "^9.1.7",
		"oxfmt": "0.58.0",
		"oxlint": "1.73.0",
		"turbo": "2.10.4"
	},
	"packageManager": "pnpm@11.11.0"
}
