{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"//#format": {},
		"//#format:fix": {
			"cache": false,
			"dependsOn": ["//#lint:fix"]
		},
		"//#lint": {},
		"//#lint:fix": {
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		}
	}
}
